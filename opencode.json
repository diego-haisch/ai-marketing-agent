{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "mcp": {
    "linkedin": {
      "type": "local",
      "command": ["npx", "-y", "@isteam/linkedin-mcp"],
      "enabled": true,
      "environment": {
        "LINKEDIN_ACCESS_TOKEN": "{env:LINKEDIN_ACCESS_TOKEN}",
        "LINKEDIN_PERSON_ID": "{env:LINKEDIN_PERSON_ID}",
        "LINKEDIN_MODE": "member"
      }
    }
  }
}
